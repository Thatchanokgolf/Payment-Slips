# Anthropic API key — used for vision-based slip extraction.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Neon Postgres connection string.
# Create a database at https://neon.tech and copy its pooled connection string.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Optional — port the server listens on (defaults to 3000).
# PORT=3000

# --- Google Sheets sync (optional) -----------------------------------------
# Leave these unset to disable the sync; the app then works exactly as before.
# The target Sheet ('ฟอร์มจ่ายเงินใหม่' tab) and Drive image folder are already
# configured in lib/sheets.js, so you only need the two credentials below.
# Create a Google Cloud service account, enable the Sheets + Drive APIs, then
# share BOTH the Sheet and the Drive folder (Editor) with this email:
GOOGLE_SERVICE_ACCOUNT_EMAIL=payment-slips@your-project.iam.gserviceaccount.com
# Paste the whole private key on ONE line, in double quotes, with \n for newlines:
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvg...\n...\n-----END PRIVATE KEY-----\n"

# Optional overrides (defaults live in lib/sheets.js):
# GOOGLE_SHEET_ID=...
# GOOGLE_SHEET_TAB=ฟอร์มจ่ายเงินใหม่
# GOOGLE_DRIVE_FOLDER_ID=...
