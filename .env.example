# Anthropic API key — used for vision-based slip extraction.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Neon Postgres connection string.
# Create a database at https://neon.tech and copy its pooled connection string.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Optional — port the server listens on (defaults to 3000).
# PORT=3000
